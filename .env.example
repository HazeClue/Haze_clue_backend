# ── Database ──────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/haze_clue

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_64_CHAR_SECRET_KEY
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS (comma-separated origins) ───────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3003,https://hazeclue.netlify.app
FRONTEND_URL=http://localhost:3003

# ── OAuth - Google (Optional) ────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ── OAuth - Facebook (Optional) ──────────────────────────
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/auth/facebook/callback

# ── SMTP / Email (free tier: Resend, Mailgun, etc.) ──────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ── Simulation Toggle ────────────────────────────────────
USE_SIMULATION=true
